generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  UPCOMING
  PAST
  CANCELLED
}

enum OperationStatus {
  QUOTED
  PROCESSING
  SUCCEEDED
  FAILED
  EXPIRED
  BLOCKED
}

enum DocumentType {
  ITINERARY
  ETICKET
  RECEIPT
  EXCHANGE_CONFIRMATION
  REFUND_CONFIRMATION
}

enum PssScenario {
  FLEXIBLE
  EXCHANGE_SURCHARGE
  REFUND_BLOCKED
  CANCELLED_TRIP
  PAST_TRIP
  QUOTE_EXPIRED
  COMMIT_FAILURE
}

model User {
  id         String          @id @default(cuid())
  email      String          @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  sessions   Session[]
  orderLinks UserOrderLink[]

  @@map("users")
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  otpCode     String
  expiresAt   DateTime
  accessToken String?   @unique
  verifiedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserOrderLink {
  id        String        @id @default(cuid())
  userId    String
  orderId   String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     OrderShowcase @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, orderId])
  @@map("user_order_links")
}

model OrderShowcase {
  id                String              @id @default(cuid())
  pnr               String              @unique
  ticketNumber      String              @unique
  passengerFirstName String
  passengerLastName String
  route             String
  origin            String
  destination       String
  departureAt       DateTime
  arrivalAt         DateTime?
  status            OrderStatus
  currency          String              @default("EUR")
  totalAmount       Decimal             @default(0) @db.Decimal(10, 2)
  pssScenario       PssScenario
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  documents         OrderDocument[]
  events            OrderEvent[]
  links             UserOrderLink[]
  exchanges         ExchangeOperation[]
  refunds           RefundOperation[]

  @@map("orders_showcase")
}

model OrderDocument {
  id            String        @id @default(cuid())
  orderId        String
  type          DocumentType
  title         String
  fileName      String
  deliveryEmail String
  url           String
  lastSentAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         OrderShowcase @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_documents")
}

model OrderEvent {
  id        String        @id @default(cuid())
  orderId    String
  type      String
  message   String
  payload   Json?
  createdAt DateTime      @default(now())
  order     OrderShowcase @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_events")
}

model ExchangeOperation {
  id             String          @id @default(cuid())
  orderId         String
  pssQuoteId     String          @unique
  quoteAmount    Decimal         @db.Decimal(10, 2)
  currency       String          @default("EUR")
  changeFee      Decimal         @default(0) @db.Decimal(10, 2)
  fareDifference Decimal         @default(0) @db.Decimal(10, 2)
  requiresPayment Boolean        @default(false)
  status         OperationStatus @default(QUOTED)
  reason         String?
  expiresAt      DateTime?
  confirmedAt    DateTime?
  completedAt    DateTime?
  idempotencyKey String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  order          OrderShowcase   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("exchange_operations")
}

model RefundOperation {
  id             String          @id @default(cuid())
  orderId         String
  pssQuoteId     String          @unique
  quoteAmount    Decimal         @db.Decimal(10, 2)
  currency       String          @default("EUR")
  refundFee      Decimal         @default(0) @db.Decimal(10, 2)
  status         OperationStatus @default(QUOTED)
  reason         String?
  expiresAt      DateTime?
  confirmedAt    DateTime?
  completedAt    DateTime?
  idempotencyKey String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  order          OrderShowcase   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("refund_operations")
}

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  operation   String
  orderId     String
  responseRef String?
  createdAt   DateTime @default(now())

  @@map("idempotency_keys")
}
